# PostgreSQL (required for Spring Boot backend)
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/finsense

# Flask ML microservice
FINSENSE_ML_BASE_URL=http://localhost:5000

# JWT (min 32 characters for HS256)
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Spring profile: use "dev" for in-memory H2 when Postgres is not running
# SPRING_PROFILES_ACTIVE=dev

